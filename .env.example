# --- Google AI Studio (free) ---
# Get a key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Default to Gemma 3 27B. Swap to gemini-2.5-flash if Gemma's tool-calling
# misbehaves (free tier of both works with the same API key).
LLM_MODEL=gemma-3-27b-it

# --- Spotify ---
# Create an app at https://developer.spotify.com/dashboard
# Set redirect URI to http://localhost:3000/api/callback in the dashboard.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/callback

# --- Genius (optional, for lyrics ingestion) ---
# Get a token at https://genius.com/api-clients
GENIUS_TOKEN=

# --- Embeddings (runs locally, no key needed) ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
